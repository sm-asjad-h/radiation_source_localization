# --- Datasets & Data ---
# Ignore all CSV, Excel, and pickle files
*.csv
*.xlsx
*.pkl
*.parquet

# --- Models & Weights ---
# Ignore saved model binaries and checkpoints
*.pth
*.pt
*.h5
*.ckpt

# --- Jupyter Notebooks ---
# Ignore checkpoints created by Jupyter/Colab
.ipynb_checkpoints/
# --- Python & Environment ---
# Compiled python files
__pycache__/
*.py[cod]

# Virtual environments and secrets
venv/
env/
.env
# --- System / OS Junk ---
.DS_Store
Thumbs.db

# IDE settings (VS Code, PyCharm)
.vscode/
.idea/
