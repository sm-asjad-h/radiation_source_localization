*.csv
*.xlsx
*.pkl
*.parquet

# --- Models & Weights ---
# Ignore saved model binaries and checkpoints
*.pth
*.pt
*.h5
*.ckpt

# --- Jupyter Notebooks ---
# Ignore checkpoints created by Jupyter/Colab
.ipynb_checkpoints/

# --- System / OS Junk ---
.DS_Store
Thumbs.db

# IDE settings (VS Code, PyCharm)
.vscode/
.idea/
